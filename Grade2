  ham.addEventListener('click',function(){panel.classList.contains('open')?closeP():openP();});
  closeB.addEventListener('click',closeP);
  ov.addEventListener('click',closeP);
  links.addEventListener('click',function(e){if(e.target.tagName==='A')closeP();});
  document.addEventListener('keydown',function(e){if(e.key==='Escape')closeP();});
  document.getElementById('navTopBtn').addEventListener('click',function(){window.scrollTo({top:0,behavior:'smooth'});});
  function hints(){document.querySelectorAll('.table-scroll').forEach(function(w){
    if(w.scrollWidth>w.clientWidth+2){w.classList.add('has-overflow');}else{w.classList.remove('has-overflow');}
  });}
  window.addEventListener('resize',hints);window.addEventListener('load',hints);hints();
  document.querySelectorAll('.table-scroll').forEach(function(w){
    w.addEventListener('scroll',function(){if(w.scrollLeft>12)w.classList.remove('has-overflow');},{passive:true});
  });
})();

</script>

