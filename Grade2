  .feedback.incorrect{background:#f5d8d8;color:#8c2c2c;}
  .reveal-btn{display:inline-block;margin-top:8px;font-size:13.5px;background:var(--gold);color:#fff;border:none;padding:6px 14px;border-radius:20px;cursor:pointer;font-family:inherit;}
  .reveal-content{display:none;margin-top:10px;background:var(--gold-soft);border-radius:8px;padding:10px 14px;font-size:14px;}
