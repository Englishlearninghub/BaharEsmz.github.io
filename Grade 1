/* ============================================================
   SITE FRAME (added): fixed top nav + progress bar, slide-out
   contents panel with creator branding, sticky section headers,
   responsive & overflow fixes, footer, speaking/listening cards
   ============================================================ */
:root{--navh:52px;}
html{scroll-behavior:smooth;}
body{overflow-x:hidden;padding-top:calc(var(--navh) + 4px);}
[id]{scroll-margin-top:calc(var(--navh) + 20px);}
img,svg,table{max-width:100%;}
.wrap p,.wrap li,.wrap td,.wrap th,.wrap h1,.wrap h2,.wrap h3{overflow-wrap:break-word;word-break:break-word;}
.masthead{margin-left:0;margin-right:0;}
.debate-band{margin-left:0;margin-right:0;}

/* Progress bar: fixed, always visible below the nav */
.progress-track{position:fixed;top:var(--navh);left:0;right:0;height:4px;z-index:120;}

/* Top navigation bar */
.nav-bar{position:fixed;top:0;left:0;right:0;height:var(--navh);background:var(--green);color:#FFFFFF;display:flex;align-items:center;gap:10px;padding:0 12px;z-index:130;box-shadow:0 2px 12px rgba(0,0,0,.20);}
.nav-btn{min-width:44px;min-height:44px;background:transparent;border:none;color:#FFFFFF;font-size:20px;cursor:pointer;border-radius:8px;display:inline-flex;align-items:center;justify-content:center;font-family:'Inter',Arial,sans-serif;transition:background .15s;}
.nav-btn:hover{background:rgba(255,255,255,.14);}
.nav-top{font-size:13px;font-weight:700;letter-spacing:.03em;white-space:nowrap;padding:0 10px;}
.nav-brand{flex:1;min-width:0;display:flex;flex-direction:column;line-height:1.25;}
.nav-brand-week{font-family:'Inter',Arial,sans-serif;font-size:10.5px;letter-spacing:.13em;text-transform:uppercase;opacity:.75;}
.nav-brand-title{font-family:'Playfair Display',Cambria,Georgia,serif;font-size:15px;font-weight:700;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}

/* Slide-out contents panel */
.nav-overlay{position:fixed;inset:0;background:rgba(0,0,0,.45);opacity:0;pointer-events:none;transition:opacity .25s;z-index:135;}
.nav-overlay.open{opacity:1;pointer-events:auto;}
.nav-panel{position:fixed;top:0;bottom:0;left:0;width:min(330px,88vw);background:#FFFFFF;z-index:140;transform:translateX(-103%);transition:transform .28s ease;display:flex;flex-direction:column;box-shadow:6px 0 28px rgba(0,0,0,.22);}
.nav-panel.open{transform:translateX(0);}
.nav-panel-head{display:flex;align-items:center;justify-content:space-between;padding:8px 10px 8px 20px;font-family:'Inter',Arial,sans-serif;font-size:11px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--ink-soft);border-bottom:1px solid var(--paper-line);}
.nav-panel-head .nav-btn{color:var(--ink);font-size:16px;}
.nav-panel-links{flex:1;overflow-y:auto;padding:10px 8px;}
.nav-panel-links a{display:flex;align-items:center;min-height:44px;padding:6px 14px;border-radius:8px;text-decoration:none;color:var(--ink);font-family:'Inter',Arial,sans-serif;font-size:14px;font-weight:600;line-height:1.4;}
.nav-panel-links a:hover{background:var(--paper);color:var(--orange);}
/* Branding zone: visually separated from navigation */
.nav-panel-brand{border-top:2px solid var(--paper-line);background:var(--paper);padding:16px 20px 18px;}
.nav-panel-brand .brand-name{font-family:'Playfair Display',Cambria,Georgia,serif;font-size:16px;font-weight:700;color:var(--ink);margin-bottom:4px;}
.nav-panel-brand .brand-line{font-family:'Inter',Arial,sans-serif;font-size:12.5px;color:var(--ink-soft);margin-bottom:10px;line-height:1.55;}
.nav-panel-brand a{display:flex;align-items:center;min-height:40px;font-family:'Inter',Arial,sans-serif;font-size:13px;color:var(--orange);text-decoration:none;font-weight:600;}
.nav-panel-brand a:hover{text-decoration:underline;}
.nav-panel-brand .brand-copy{margin-top:10px;font-family:'Inter',Arial,sans-serif;font-size:11.5px;color:var(--ink-soft);}

/* Sticky section headers: current section title stays visible */
.tab-header{position:sticky;top:calc(var(--navh) + 4px);z-index:60;background:var(--paper);padding:10px 0 8px;}

/* Scrollable table wrapper with mobile hint */
.table-scroll{overflow-x:auto;-webkit-overflow-scrolling:touch;max-width:100%;}
.table-scroll table{max-width:none;}
.table-scroll.has-overflow{background:linear-gradient(to left,rgba(0,0,0,.12),rgba(0,0,0,0) 26px) right center / 26px 100% no-repeat;}
.table-scroll.has-overflow::before{content:'scroll \2192';display:block;font-family:'Inter',Arial,sans-serif;font-size:11px;font-weight:700;letter-spacing:.06em;color:var(--ink-soft);text-align:right;padding:0 6px 4px;}

/* Speaking & Listening sections */
.tb-speak{background:var(--blue);color:#FFFFFF;}
.tb-listen{background:var(--plum);color:#FFFFFF;}
.section-intro{font-family:'Inter',Arial,sans-serif;font-size:14.5px;color:var(--ink-soft);margin:0 0 18px;line-height:1.65;}
.speak-card{background:#FFFFFF;border-radius:10px;padding:22px 26px;margin-bottom:18px;box-shadow:0 2px 10px rgba(0,0,0,.07);border-left:4px solid var(--blue);}
.speak-type{display:inline-block;font-family:'Inter',Arial,sans-serif;font-size:11px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--blue);margin-bottom:8px;}
.speak-card h3{font-family:'Playfair Display',Cambria,Georgia,serif;font-size:18px;margin:0 0 10px;color:var(--ink);}
.speak-card p{margin:0 0 10px;}
.speak-card ul{margin:0 0 10px 20px;padding:0;}
.speak-card li{margin-bottom:6px;}
.speak-how{background:var(--paper);border-radius:8px;padding:12px 16px;font-family:'Inter',Arial,sans-serif;font-size:13.5px;line-height:1.65;margin-top:12px;}
.media-card{background:#FFFFFF;border-radius:10px;padding:22px 26px;margin-bottom:18px;box-shadow:0 2px 10px rgba(0,0,0,.07);border-left:4px solid var(--plum);}
.media-head{display:flex;align-items:baseline;gap:12px;flex-wrap:wrap;margin-bottom:8px;}
.media-head h3{font-family:'Playfair Display',Cambria,Georgia,serif;font-size:18px;margin:0;color:var(--ink);}
.media-platform{font-family:'Inter',Arial,sans-serif;font-size:11.5px;font-weight:700;letter-spacing:.07em;text-transform:uppercase;color:var(--plum);}
.media-card p{margin:0 0 10px;}
.media-task{border-left:3px solid var(--plum);background:var(--paper);padding:10px 14px;font-family:'Inter',Arial,sans-serif;font-size:13.5px;line-height:1.65;margin-top:10px;border-radius:0 8px 8px 0;}
.tip-box{border:2px dashed var(--blue);border-radius:10px;padding:18px 22px;background:#FFFFFF;margin-top:6px;}
.tip-box h3{font-family:'Playfair Display',Cambria,Georgia,serif;font-size:16px;margin:0 0 10px;color:var(--blue);}
.tip-box ul{margin:0 0 0 20px;padding:0;}
.tip-box li{margin-bottom:6px;font-size:14.5px;}

/* Footer */
.site-footer{background:var(--green);color:#FFFFFF;margin-top:56px;padding:34px 24px 40px;}
.site-footer-inner{max-width:920px;margin:0 auto;text-align:center;}
.footer-copy{font-family:'Inter',Arial,sans-serif;font-size:13.5px;font-weight:700;margin:0 0 6px;}
.footer-line{font-family:'Playfair Display',Cambria,Georgia,serif;font-style:italic;font-size:14.5px;opacity:.88;margin:0 0 12px;}
.footer-links{display:flex;justify-content:center;gap:10px;flex-wrap:wrap;align-items:center;margin:0 0 10px;}
.footer-links a{color:#FFFFFF;font-family:'Inter',Arial,sans-serif;font-size:13.5px;font-weight:600;text-decoration:none;border-bottom:1px solid rgba(255,255,255,.4);padding:8px 2px;min-height:44px;display:inline-flex;align-items:center;}
.footer-links a:hover{border-bottom-color:#FFFFFF;}
.footer-dot{opacity:.5;}
.footer-note{font-family:'Inter',Arial,sans-serif;font-size:12.5px;opacity:.72;margin:0;}

/* Mobile refinements (375px-safe) */
@media(max-width:600px){
  .wrap{padding-left:18px;padding-right:18px;}
  .masthead{padding:34px 20px 28px;}
  .grammar-box,.card{padding:20px 18px;}
