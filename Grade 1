<script>
window.addEventListener('scroll', function(){
  var h = document.documentElement;
  var scrolled = (h.scrollTop) / (h.scrollHeight - h.clientHeight) * 100;
  document.getElementById('progress-bar').style.width = scrolled + '%';
});

var tfData = [
  {q:"Elena is from Mexico.", a:false, exp:"False — Elena is from Poland. Diego is from Mexico."},
  {q:"Diego is a little tired.", a:true, exp:"True — he says 'A little tired!'"},
  {q:"Elena has got three children.", a:true, exp:"True — 'I've got three children.'"},
  {q:"Diego has got one brother.", a:false, exp:"False — he has got two brothers and one sister."},
  {q:"Sam asks the class to open their books.", a:true, exp:"True — 'open your books to page one!'"}
];
var tfContainer = document.getElementById('tf-quiz');
var tfCorrectCount = 0, tfAnswered = 0;
tfData.forEach(function(item, i){
  var div = document.createElement('div');
  div.className = 'quiz-item';
  div.innerHTML = '<div class="q-text">' + (i+1) + '. ' + item.q + '</div>' +
    '<div class="tf-btns"><button data-val="true">True</button><button data-val="false">False</button></div>' +
    '<div class="feedback"></div>';
  tfContainer.appendChild(div);
  var buttons = div.querySelectorAll('.tf-btns button');
  var fb = div.querySelector('.feedback');
  var done = false;
  buttons.forEach(function(btn){
    btn.addEventListener('click', function(){
      if(done) return;
      done = true; tfAnswered++;
      var val = (btn.getAttribute('data-val') === 'true');
      if(val === item.a){
        fb.className = 'feedback correct'; fb.textContent = '✔ Correct! ' + item.exp; tfCorrectCount++;
      } else {
        fb.className = 'feedback incorrect'; fb.textContent = '✘ Not quite. ' + item.exp;
      }
      fb.style.display = 'block';
      document.getElementById('tf-score').textContent = 'Score: ' + tfCorrectCount + ' / ' + tfData.length + ' (answered ' + tfAnswered + ')';
    });
  });
});

var matchPairs = [
  {word:"Poland", def:"Polish"},
  {word:"Mexico", def:"Mexican"},
  {word:"Japan", def:"Japanese"},
  {word:"Brazil", def:"Brazilian"},
  {word:"France", def:"French"}
];
function shuffle(arr){ return arr.map(function(v){return [Math.random(), v];}).sort(function(a,b){return a[0]-b[0];}).map(function(v){return v[1];}); }
var wordsShuffled = shuffle(matchPairs.map(function(p){return p.word;}));
var defsShuffled = shuffle(matchPairs.map(function(p){return p.def;}));
var matchContainer = document.getElementById('match-game');
var colWords = document.createElement('div'); colWords.className = 'match-col';
var colDefs = document.createElement('div'); colDefs.className = 'match-col';
wordsShuffled.forEach(function(w){
  var d = document.createElement('div'); d.className = 'match-item'; d.textContent = w; d.setAttribute('data-word', w);
  colWords.appendChild(d);
});
defsShuffled.forEach(function(def){
  var d = document.createElement('div'); d.className = 'match-item'; d.textContent = def; d.setAttribute('data-def', def);
  colDefs.appendChild(d);
});
matchContainer.appendChild(colWords); matchContainer.appendChild(colDefs);
var selectedWord = null, selectedDef = null, matchCount = 0;
function checkMatch(){
  if(selectedWord && selectedDef){
    var w = selectedWord.getAttribute('data-word');
    var pair = matchPairs.find(function(p){return p.word === w;});
    if(pair && pair.def === selectedDef.getAttribute('data-def')){
      selectedWord.classList.add('matched'); selectedDef.classList.add('matched');
      selectedWord.classList.remove('selected'); selectedDef.classList.remove('selected');
      matchCount++;
      document.getElementById('match-score').textContent = 'Matched: ' + matchCount + ' / ' + matchPairs.length;
    } else {
      selectedWord.classList.remove('selected'); selectedDef.classList.remove('selected');
    }
    selectedWord = null; selectedDef = null;
  }
}
colWords.querySelectorAll('.match-item').forEach(function(item){
  item.addEventListener('click', function(){
    if(item.classList.contains('matched')) return;
    colWords.querySelectorAll('.match-item').forEach(function(i){ if(i!==item) i.classList.remove('selected'); });
    item.classList.toggle('selected');
    selectedWord = item.classList.contains('selected') ? item : null;
    checkMatch();
  });
});
colDefs.querySelectorAll('.match-item').forEach(function(item){
  item.addEventListener('click', function(){
    if(item.classList.contains('matched')) return;
    colDefs.querySelectorAll('.match-item').forEach(function(i){ if(i!==item) i.classList.remove('selected'); });
    item.classList.toggle('selected');
    selectedDef = item.classList.contains('selected') ? item : null;
    checkMatch();
  });
});

var mcData = [
  {q:"I ___ Elena.", options:["am","is","are"], correct:0},
  {q:"___ you from Mexico?", options:["Am","Is","Are"], correct:2},
  {q:"She ___ happy.", options:["am","is","are"], correct:1},
  {q:"He ___ got one sister.", options:["'ve","'s","are"], correct:1}
];
var mcContainer = document.getElementById('mc-quiz');
mcData.forEach(function(item, i){
  var div = document.createElement('div'); div.className = 'quiz-item';
  var btnsHtml = item.options.map(function(opt, idx){ return '<button data-idx="'+idx+'">'+opt+'</button>'; }).join('');
  div.innerHTML = '<div class="q-text">' + (i+1) + '. ' + item.q + '</div><div class="mc-btns">' + btnsHtml + '</div><div class="feedback"></div>';
  mcContainer.appendChild(div);
  var fb = div.querySelector('.feedback');
  var done = false;
  div.querySelectorAll('.mc-btns button').forEach(function(btn){
    btn.addEventListener('click', function(){
      if(done) return; done = true;
      var idx = parseInt(btn.getAttribute('data-idx'));
      if(idx === item.correct){ fb.className='feedback correct'; fb.textContent = '✔ Correct!'; }
      else { fb.className='feedback incorrect'; fb.textContent = '✘ The correct answer was: ' + item.options[item.correct]; }
      fb.style.display = 'block';
    });
  });
});

function checkFillBlanks(){
  var inputs = document.querySelectorAll('.fill-blank input');
  var correct = 0;
  inputs.forEach(function(inp){
    var val = inp.value.trim().toLowerCase();
    var ans = inp.getAttribute('data-answer').toLowerCase();
    if(val === ans){ inp.style.borderColor = '#215c3d'; inp.style.color = '#215c3d'; correct++; }
    else { inp.style.borderColor = '#8c2c2c'; inp.style.color = '#8c2c2c'; }
  });
  document.getElementById('fill-feedback').textContent = correct + ' / ' + inputs.length + ' correct. (Correct answers shown in green, check spelling on red ones.)';
}

document.getElementById('writing-box').addEventListener('input', function(){
  var text = this.value.trim();
  var count = text.length ? text.split(/\s+/).length : 0;
  var el = document.getElementById('word-count');
  el.textContent = count + ' words';
  el.style.color = (count >= 20 && count <= 30) ? '#215c3d' : '#5a6863';
});

/* Site frame (added): contents panel, back-to-top, table scroll hints */
(function(){
  var panel=document.getElementById('navPanel'),ov=document.getElementById('navOverlay'),
